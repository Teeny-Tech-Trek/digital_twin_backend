# Digital Twin Backend Configuration
# Copy this to .env and fill in actual values

# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/digitaltwin?retryWrites=true&w=majority

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# TEMPORARY: set to "true" to bypass all express-rate-limit gates
# (apiLimiter / authLimiter / ingestionPollLimiter). Intended for active
# NetTwin QA/demo so rapid chat refreshes don't 429. MUST be unset or
# "false" before large-scale public launch.
DISABLE_RATE_LIMIT=true

# JWT Secrets (MUST be at least 32 characters, use strong random values)
# Generate with: node -e "consggggole.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long_here_replace_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_at_least_32_characters_long_here_replace_this

# Session Secret (for Passport compatibility)
SESSION_SECRET=your_session_secret_key_here

# Google OAuth Credentials
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Frontend URL (for CORS and redirects)
CLIENT_URL=http://localhost:5173

# ──────────────────────────────────────────────────────────────────────
# Email (SMTP via Nodemailer)
#
# Used for: verification emails, password reset, and the
# "your digital twin has paused" notification when a twin owner hits
# their monthly chat-message limit.
#
# Recommended setup for launch: Gmail with an App Password.
#   1. Enable 2-Step Verification on the Google account.
#   2. Create an App Password at https://myaccount.google.com/apppasswords
#   3. Paste the 16-character app password as SMTP_PASS (no spaces).
#
# Any provider that speaks SMTP (Mailgun, Resend, SES, Brevo, …) works the
# same way — just swap the host/port/credentials.
#
# When any of these are missing, the mailer falls back to console logging
# so dev never blocks on email. Production MUST set all four.
# ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=NetTwin <your-gmail-address@gmail.com>

# AWS S3 (Optional - for file uploads)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=your-bucket-name

# ──────────────────────────────────────────────────────────────────────
# Centralized TTT Payment Service (billing integration)
#
# NetTwin proxies all billing/payment logic through the TTT Payment Service
# living at ttt-payment-service/. These three variables must match the keys
# configured on that service. See src/modules/billing/billing.constants.js.
#
# CENTRAL_BILLING_SERVICE_URL
#   Base URL of the TTT Payment Service. In production point this at the
#   deployed instance (e.g. https://billingservice.techtrekkers.ai).
# CENTRAL_BILLING_API_KEY
#   Public-tier key (reserved for future rate-limiting); safe in client
#   bundles. Currently unused on the wire but kept to mirror NexEstate.
# CENTRAL_BILLING_INTERNAL_API_KEY
#   Shared secret used in BOTH directions:
#     (a) NetTwin → TTT for internal endpoints (plan lookups, latest payment)
#     (b) TTT → NetTwin for the activation webhook (/api/billing/internal/activate-plan)
#   Must EXACTLY match TTT's INTERNAL_API_KEY value.
# ──────────────────────────────────────────────────────────────────────
CENTRAL_BILLING_SERVICE_URL=http://localhost:4000
CENTRAL_BILLING_API_KEY=dev-key-12345
CENTRAL_BILLING_INTERNAL_API_KEY=internal-dev-key-12345

# ──────────────────────────────────────────────────────────────────────
# Payments kill-switch
#
# Set to "false" to disable the Razorpay checkout flow entirely. When
# disabled:
#   - POST /api/billing/create-order returns 503 PAYMENTS_DISABLED
#   - The frontend (with VITE_PAYMENTS_ENABLED=false) shows a
#     "Contact us" modal pointing to SUPPORT_CONTACT_EMAIL.
# Defaults to "true" if unset — production must opt in to disabling.
#
# Anyone with .env access can flip this without a deploy. Restart the
# Node process so the new value is picked up (nodemon does this auto).
# ──────────────────────────────────────────────────────────────────────
PAYMENTS_ENABLED=true
SUPPORT_CONTACT_EMAIL=ttt.teenytechtrek@gmail.com

# Logging
LOG_LEVEL=info

# CORS Settings
# The following origins are always allowed (hardcoded in src/server.js):
#   - https://nettwin.techtrekkers.ai      (production frontend)
#   - https://nettwin-test.vercel.app      (Vercel preview / staging)
#   - https://digitaltwin.techtrekkers.ai  (legacy production frontend)
#   - process.env.CLIENT_URL               (whatever you set above)
#   - http(s)://localhost:<any-port>       (Vite/CRA dev servers)
#
# Use ADDITIONAL_ALLOWED_ORIGINS to whitelist extra URLs without a code
# change (comma-separated, no spaces around commas required — they're trimmed).
# Trailing slashes are normalized away so "https://x.com" and "https://x.com/"
# both work.
ADDITIONAL_ALLOWED_ORIGINS=

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif
